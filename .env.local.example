NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NASA_FIRMS_API_KEY=""

# CRON_SECRET — server-only. Must equal the value of `supabase secrets set
# CRON_SECRET` so that the `check-fires` Edge Function accepts manual
# triggers from `/api/check-fires/run`. Without this, the "Ejecutar
# detector de prueba" button in /dashboard returns 503.
#
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""
